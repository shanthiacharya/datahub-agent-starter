# Copy to .env and fill in.  cp .env.example .env

# --- DataHub connection (local quickstart) ---
# DataHubClient.from_env() reads these two.
DATAHUB_GMS_URL=http://localhost:8080
DATAHUB_GMS_TOKEN=your-personal-access-token   # UI -> Settings -> Access Tokens

# --- LLM (bring your own) ---
# Default provider is Anthropic. Set the key that matches your provider.
ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENAI_API_KEY=your-openai-api-key
# GOOGLE_API_KEY=your-google-api-key

# Optional: override the model. Format is "provider:model".
# AGENT_MODEL=anthropic:claude-sonnet-5
# AGENT_MODEL=openai:gpt-5
# AGENT_MODEL=google_genai:gemini-2.5-pro
